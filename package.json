{
  "name": "boldteq-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:audit": "playwright test tests/homepage.spec.ts",
    "visual-diff": "node scripts/visual-diff.mjs",
    "visual-diff:all": "node scripts/visual-diff.mjs --all --gate=5 --page-height-tolerance=2",
    "visual-diff:gate": "node scripts/visual-diff.mjs --gate=5 --page-height-tolerance=2",
    "lighthouse": "node scripts/lighthouse.mjs",
    "lighthouse:all": "node scripts/lighthouse.mjs --all --gate",
    "axe": "node scripts/axe-scan.mjs",
    "axe:all": "node scripts/axe-scan.mjs --all --gate",
    "snapshot-live": "node scripts/snapshot-live.mjs",
    "component-diff": "node scripts/component-diff.mjs",
    "audit:all": "pnpm visual-diff:all && pnpm lighthouse:all && pnpm axe:all"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@sanity/image-url": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-sanity": "^12.2.2",
    "next-sitemap": "^4.2.3",
    "posthog-js": "^1.367.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "lighthouse": "^12.8.2",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
